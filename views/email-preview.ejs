<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Email preview</title>
  <%- include('partials-style') %>
</head>
<body>
  <nav><a href="/">&larr; Back to dashboard</a></nav>
  <h1>Email for <%= company.company_label || company.contact_email %></h1>
  <p><strong>To:</strong> <%= company.contact_email %></p>
  <p><strong>Subject:</strong> <%= subject %></p>
  <pre id="body"><%= body %></pre>
  <button onclick="navigator.clipboard.writeText(document.getElementById('body').innerText)">Copy email body</button>
  <p class="muted">Sending isn't wired up yet — copy this into your email client, or add SMTP/API credentials later to send automatically.</p>
</body>
</html>
