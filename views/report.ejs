<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Survey Report</title>
  <%- include('partials-style') %>
</head>
<body>
  <nav><a href="/">&larr; Back to dashboard</a></nav>
  <h1>Employment Survey — Compiled Report</h1>

  <h2>Summary</h2>
  <div class="card"><p style="margin:0;"><%= report.summaryText %></p></div>

  <h2>Overview</h2>
  <table class="card-table">
    <tr><th>Companies responded</th><td><%= report.totalCompanies %></td></tr>
    <tr><th>Total employees recorded</th><td><%= report.totalEmployees %></td></tr>
    <tr><th>Weekly-paid employees</th><td><%= report.weeklyCount %></td></tr>
    <tr><th>Monthly-paid employees</th><td><%= report.monthlyCount %></td></tr>
    <tr><th>Frontier workers</th><td><%= report.frontierWorkerCount %></td></tr>
    <tr><th>Detached workers</th><td><%= report.detachedWorkerCount %></td></tr>
    <tr><th>Average hours worked</th><td><%= report.avgHours.toFixed(1) %></td></tr>
    <tr><th>Average overtime hours</th><td><%= report.avgOvertime.toFixed(1) %></td></tr>
    <tr><th>Average gross earnings</th><td>£<%= report.avgEarnings.toFixed(2) %></td></tr>
    <tr><th>Average benefits value</th><td>£<%= report.avgBenefits.toFixed(2) %></td></tr>
  </table>

  <h2>Breakdown by Sex</h2>
  <table class="card-table">
    <% Object.entries(report.sexBreakdown).forEach(([k,v]) => { %>
      <tr><th><%= k %></th><td><%= v %></td></tr>
    <% }) %>
  </table>

  <h2>Breakdown by Employment Type</h2>
  <table class="card-table">
    <% Object.entries(report.employmentTypeBreakdown).forEach(([k,v]) => { %>
      <tr><th><%= k %></th><td><%= v %></td></tr>
    <% }) %>
  </table>

  <h2>Breakdown by Nationality</h2>
  <table class="card-table">
    <% Object.entries(report.nationalityBreakdown).forEach(([k,v]) => { %>
      <tr><th><%= k %></th><td><%= v %></td></tr>
    <% }) %>
  </table>

  <h2>Breakdown by Occupation</h2>
  <table class="card-table">
    <% Object.entries(report.occupationBreakdown).forEach(([k,v]) => { %>
      <tr><th><%= k %></th><td><%= v %></td></tr>
    <% }) %>
  </table>

  <% if (report.outliers.length) { %>
    <h2>Earnings Outliers</h2>
    <table class="card-table">
      <thead><tr><th>Occupation</th><th>Section</th><th>Gross Earnings</th></tr></thead>
      <% report.outliers.forEach(o => { %>
        <tr><td><%= o.occupation %></td><td><%= o.section %></td><td>£<%= o.gross_earnings.toFixed(2) %></td></tr>
      <% }) %>
    </table>
  <% } %>

  <h2>Responding Companies</h2>
  <table class="card-table">
    <thead><tr><th>Name</th><th>Address</th><th>Submitted</th></tr></thead>
    <% report.companies.forEach(c => { %>
      <tr><td><%= c.registered_name %></td><td><%= c.address %></td><td><%= c.submitted_at %></td></tr>
    <% }) %>
  </table>
</body>
</html>
