<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Employment Survey 2025</title>
  <%- include('partials-style') %>
  <style>
    .section-card {
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 20px 22px;
      margin: 16px 0 30px;
      background: var(--surface);
      box-shadow: var(--shadow-card);
    }
    .section-card h2 { margin-top: 0; }
    .section-card > p.muted { margin-top: -4px; }

    .nil-row {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin: 10px 0 14px;
      font-size: 0.9rem;
      font-weight: 500;
      cursor: pointer;
      user-select: none;
    }
    .nil-row input { width: auto; cursor: pointer; accent-color: var(--primary); }

    .table-scroll {
      overflow-x: auto;
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      background: white;
    }

    /* Header and data rows share this exact column template so they always line up */
    .emp-cols {
      display: grid;
      grid-template-columns: 72px 72px 90px minmax(160px, 1fr) 130px 72px 80px 80px 90px 100px 100px 36px;
      column-gap: 8px;
      align-items: center;
      min-width: 1180px;
    }
    .emp-header {
      padding: 11px 10px;
      background: #f8f8fd;
      color: var(--text-muted);
      font-size: 0.7rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border-bottom: 1px solid var(--border);
      border-radius: var(--radius-md) var(--radius-md) 0 0;
    }
    .emp-row {
      padding: 8px 10px;
      border-bottom: 1px solid var(--border);
      transition: background 0.12s ease;
    }
    .emp-row:hover { background: #fafaff; }
    .emp-row:last-child { border-bottom: none; }

    .emp-cols select, .emp-cols input {
      width: 100%;
      box-sizing: border-box;
      font-size: 0.82rem;
      padding: 6px 8px;
      height: 34px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: white;
    }
    .emp-cols select { cursor: pointer; }

    .remove-btn {
      background: none;
      border: none;
      color: #dc2626;
      font-size: 1rem;
      cursor: pointer;
      padding: 4px;
      line-height: 1;
      justify-self: center;
      box-shadow: none !important;
      transform: none !important;
    }
    .remove-btn:hover { color: #b91c1c; background: none; }

    .add-row-btn { margin-top: 10px; }

    .field-error { border-color: #dc2626 !important; box-shadow: 0 0 0 3px rgba(220,38,38,0.15) !important; }
    .error-msg { color: #dc2626; font-size: 0.85rem; margin: 4px 0; font-weight: 600; }

    @media (max-width: 700px) {
      .row { flex-direction: column; align-items: stretch; }
      .row > div { width: 100%; }
      .section-card { padding: 14px; }
    }
  </style>
</head>
<body>
  <h1>Employment Survey 2025</h1>
  <p class="muted">For the pay week including 10 October 2025, and the month of October 2025. All replies are treated in confidence. If your company has no employees to report, tick the "Nil return" box for that section.</p>

  <div id="error-summary" class="error-msg" style="display:none;"></div>

  <form method="POST" action="/survey/<%= company.token %>" id="survey-form">
    <div class="section-card">
      <h2 style="margin-top:0;">Employer Details</h2>
      <div class="row">
        <div><label>Registered name of firm/establishment *</label><input type="text" name="registered_name" required></div>
        <div><label>Trading as</label><input type="text" name="trading_as"></div>
      </div>
      <div class="row">
        <div style="flex:1;"><label>Address *</label><input type="text" name="address" required style="width:100%;"></div>
      </div>
      <div class="row">
        <div><label>Tel</label><input type="text" name="tel"></div>
        <div><label>Fax</label><input type="text" name="fax"></div>
        <div><label>E-mail</label><input type="email" name="email"></div>
      </div>
      <div class="row">
        <div><label>Main goods or services provided</label><input type="text" name="main_goods_services" size="40"></div>
        <div><label>Other information</label><input type="text" name="other_info" size="40"></div>
      </div>
      <div class="row">
        <div><label>Name *</label><input type="text" name="contact_name" required></div>
        <div><label>Position</label><input type="text" name="contact_position"></div>
        <div><label>Date</label><input type="date" name="submission_date"></div>
      </div>
    </div>

    <div class="section-card">
      <h2>Section A: Weekly Paid Employees</h2>
      <p class="muted">Add one row per employee. Enter hours, overtime, total weekly gross earnings, and weekly value of benefits.</p>
      <label class="nil-row"><input type="checkbox" id="weekly-nil" onchange="toggleNil('weekly')"> Nil return — no weekly-paid employees</label>
      <div id="weekly-section">
        <div class="table-scroll">
          <div class="emp-cols emp-header">
            <div>Sex</div><div>Age</div><div>Type</div><div>Occupation *</div><div>Nationality</div>
            <div>Frontier</div><div>Detached</div><div>Hours</div><div>Overtime hrs</div>
            <div>Gross earnings</div><div>Benefits value</div><div></div>
          </div>
          <div id="weekly-rows"></div>
        </div>
        <button type="button" class="secondary add-row-btn" onclick="addRow('weekly')">+ Add weekly employee</button>
      </div>
    </div>

    <div class="section-card">
      <h2>Section B: Monthly Paid Employees</h2>
      <p class="muted">Add one row per employee. Enter monthly gross earnings and monthly value of benefits.</p>
      <label class="nil-row"><input type="checkbox" id="monthly-nil" onchange="toggleNil('monthly')"> Nil return — no monthly-paid employees</label>
      <div id="monthly-section">
        <div class="table-scroll">
          <div class="emp-cols emp-header">
            <div>Sex</div><div>Age</div><div>Type</div><div>Occupation *</div><div>Nationality</div>
            <div>Frontier</div><div>Detached</div><div>Hours</div><div>Overtime hrs</div>
            <div>Gross earnings</div><div>Benefits value</div><div></div>
          </div>
          <div id="monthly-rows"></div>
        </div>
        <button type="button" class="secondary add-row-btn" onclick="addRow('monthly')">+ Add monthly employee</button>
      </div>
    </div>

    <button type="submit">Submit survey</button>
  </form>

  <template id="row-template">
    <div class="emp-cols emp-row">
      <select name="__SECTION___sex[]"><option value="">—</option><option>Male</option><option>Female</option></select>
      <select name="__SECTION___age_band[]"><option value="">—</option><option>Under 18</option><option>18 to 24</option><option>25 and over</option></select>
      <select name="__SECTION___employment_type[]"><option value="">—</option><option>Full-time</option><option>Part-time</option></select>
      <input name="__SECTION___occupation[]" placeholder="e.g. Accounts Clerk" required>
      <select name="__SECTION___nationality[]">
        <option value="">—</option>
        <option>Gibraltarian</option><option>UK British</option><option>Other British</option>
        <option>Spanish</option><option>Moroccan</option><option>Other E.U.</option><option>Other</option>
      </select>
      <select name="__SECTION___frontier_worker[]"><option value="No">No</option><option value="Yes">Yes</option></select>
      <select name="__SECTION___detached_worker[]"><option value="No">No</option><option value="Yes">Yes</option></select>
      <input name="__SECTION___hours_worked[]" type="number" step="0.1" min="0">
      <input name="__SECTION___overtime_hours[]" type="number" step="0.1" min="0">
      <input name="__SECTION___gross_earnings[]" type="number" step="0.01" min="0">
      <input name="__SECTION___benefits_value[]" type="number" step="0.01" min="0">
      <button type="button" class="remove-btn" onclick="this.closest('.emp-row').remove()" title="Remove row">✕</button>
    </div>
  </template>

  <script>
    function addRow(section) {
      const tpl = document.getElementById('row-template').innerHTML.replaceAll('__SECTION__', section);
      const container = document.getElementById(section + '-rows');
      const wrapper = document.createElement('div');
      wrapper.innerHTML = tpl.trim();
      container.appendChild(wrapper.firstElementChild);
    }

    function toggleNil(section) {
      const nil = document.getElementById(section + '-nil').checked;
      const rows = document.getElementById(section + '-rows');
      const addBtn = document.querySelector(`#${section}-section button`);
      rows.querySelectorAll('.emp-row').forEach(row => row.remove());
      if (nil) {
        addBtn.disabled = true;
      } else {
        addBtn.disabled = false;
        addRow(section);
      }
    }

    // start each section with one row
    addRow('weekly');
    addRow('monthly');

    document.getElementById('survey-form').addEventListener('submit', function (e) {
      const invalid = this.querySelectorAll(':invalid');
      const errorBox = document.getElementById('error-summary');
      if (invalid.length) {
        e.preventDefault();
        invalid[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
        invalid[0].classList.add('field-error');
        errorBox.style.display = 'block';
        errorBox.textContent = 'Please fill in all required fields (marked *) before submitting — including the Occupation field for every employee row you have added, or tick "Nil return" if there are none.';
      } else {
        errorBox.style.display = 'none';
      }
    });
  </script>
</body>
</html>
