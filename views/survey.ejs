<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <title>Employment Survey 2025</title>
  <%- include('partials-style') %>
</head>
<body>
  <h1>Employment Survey 2025</h1>
  <p class="muted">For the pay week including 10 October 2025, and the month of October 2025. All replies are treated in confidence.</p>

  <form method="POST" action="/survey/<%= company.token %>">
    <h2>Employer Details</h2>
    <div class="row">
      <div><label>Registered name of firm/establishment</label><input type="text" name="registered_name" required></div>
      <div><label>Trading as</label><input type="text" name="trading_as"></div>
    </div>
    <div class="row">
      <div><label>Address</label><input type="text" name="address" size="50" required></div>
    </div>
    <div class="row">
      <div><label>Tel</label><input type="text" name="tel"></div>
      <div><label>Fax</label><input type="text" name="fax"></div>
      <div><label>E-mail</label><input type="email" name="email"></div>
    </div>
    <div class="row">
      <div><label>Main goods or services provided</label><input type="text" name="main_goods_services" size="40"></div>
      <div><label>Other information</label><input type="text" name="other_info" size="40"></div>
    </div>
    <div class="row">
      <div><label>Name</label><input type="text" name="contact_name" required></div>
      <div><label>Position</label><input type="text" name="contact_position"></div>
      <div><label>Date</label><input type="date" name="submission_date"></div>
    </div>

    <h2>Section A: Weekly Paid Employees</h2>
    <p class="muted">Add one row per employee. Enter hours, overtime, total weekly gross earnings, and weekly value of benefits.</p>
    <div id="weekly-rows"></div>
    <button type="button" onclick="addRow('weekly')">+ Add weekly employee</button>

    <h2>Section B: Monthly Paid Employees</h2>
    <p class="muted">Add one row per employee. Enter monthly gross earnings and monthly value of benefits.</p>
    <div id="monthly-rows"></div>
    <button type="button" onclick="addRow('monthly')">+ Add monthly employee</button>

    <h2></h2>
    <button type="submit">Submit survey</button>
  </form>

  <template id="row-template">
    <div class="emp-row">
      <select name="__SECTION___sex[]"><option value="">Sex</option><option>Male</option><option>Female</option></select>
      <select name="__SECTION___age_band[]"><option value="">Age</option><option>Under 18</option><option>18 to 24</option><option>25 and over</option></select>
      <select name="__SECTION___employment_type[]"><option value="">Type</option><option>Full-time</option><option>Part-time</option></select>
      <input name="__SECTION___occupation[]" placeholder="Occupation" required>
      <select name="__SECTION___nationality[]">
        <option value="">Nationality</option>
        <option>Gibraltarian</option><option>UK British</option><option>Other British</option>
        <option>Spanish</option><option>Moroccan</option><option>Other E.U.</option><option>Other</option>
      </select>
      <select name="__SECTION___frontier_worker[]"><option value="No">Frontier? No</option><option value="Yes">Frontier? Yes</option></select>
      <select name="__SECTION___detached_worker[]"><option value="No">Detached? No</option><option value="Yes">Detached? Yes</option></select>
      <input name="__SECTION___hours_worked[]" type="number" step="0.1" placeholder="Hours">
      <input name="__SECTION___overtime_hours[]" type="number" step="0.1" placeholder="Overtime hrs">
      <input name="__SECTION___gross_earnings[]" type="number" step="0.01" placeholder="Gross earnings">
      <input name="__SECTION___benefits_value[]" type="number" step="0.01" placeholder="Benefits value">
      <button type="button" class="danger" onclick="this.closest('.emp-row').remove()">✕</button>
    </div>
  </template>

  <script>
    function addRow(section) {
      const tpl = document.getElementById('row-template').innerHTML.replaceAll('__SECTION__', section);
      const container = document.getElementById(section + '-rows');
      const wrapper = document.createElement('div');
      wrapper.innerHTML = tpl.trim();
      container.appendChild(wrapper.firstElementChild);
    }
    // start each section with one row
    addRow('weekly');
    addRow('monthly');
  </script>
</body>
</html>
